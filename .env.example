# OpenRAG Configuration

# =============================================================================
# ChromaDB Settings
# =============================================================================
CHROMA_DB_PATH=./chroma_db

# Base name for ChromaDB collections (suffixes _traditional_v1, _contextual_v1, _graph_v1 are added)
COLLECTION_BASE_NAME=documents

# =============================================================================
# Embedding Model
# =============================================================================
# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (recommended), instructor-xl (advanced)
EMBEDDING_MODEL=all-mpnet-base-v2

# =============================================================================
# Chunking Configuration
# =============================================================================
# CHUNK_SIZE: 100–2000 tokens
CHUNK_SIZE=400
# CHUNK_OVERLAP: 0–500 tokens (must be less than CHUNK_SIZE)
CHUNK_OVERLAP=60

# =============================================================================
# RAG Type Enable/Disable Toggles
# =============================================================================
# Set to false to skip ingestion for that RAG type
TRADITIONAL_ENABLED=true
CONTEXTUAL_ENABLED=true
GRAPH_ENABLED=true

# =============================================================================
# Ollama Configuration (required for Contextual RAG and Graph RAG)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434

# Model used for context generation (Contextual RAG)
OLLAMA_CONTEXT_MODEL=llama3.2:3b

# Timeout in seconds for Ollama API calls (range: 10–600)
OLLAMA_TIMEOUT=300.0

# Maximum number of retry attempts for Ollama requests (range: 1–10)
OLLAMA_MAX_RETRIES=3

# Enable fallback context generation when Ollama is unavailable
OLLAMA_FALLBACK_ENABLED=true

# =============================================================================
# Contextual RAG Configuration
# =============================================================================
# Number of chunks to process concurrently for context generation (range: 1–50)
CONTEXTUAL_BATCH_SIZE=10

# Chunk size for contextual RAG in tokens — larger than traditional due to context overhead (range: 100–2000)
CONTEXTUAL_CHUNK_SIZE=800

# =============================================================================
# Graph RAG Configuration (requires Ollama + Neo4j)
# =============================================================================
# Graph database backend
GRAPH_DATABASE=neo4j

# Ollama model used for entity extraction
GRAPH_ENTITY_MODEL=llama3.2:3b

# Maximum graph traversal hops for queries (range: 1–5)
GRAPH_MAX_HOPS=2

# Batch size for entity extraction (range: 1–50)
GRAPH_BATCH_SIZE=10

# =============================================================================
# Neo4j Connection Settings
# =============================================================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# =============================================================================
# Query Configuration
# =============================================================================
# Default minimum similarity score threshold for all RAG types (range: 0.0–1.0)
# Can be overridden per-query via the MCP tool call
MIN_SIMILARITY=0.1

# =============================================================================
# Logging
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
